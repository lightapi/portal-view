# Environment variables
# VITE_BASE_PATH is the base path where the frontend app is served (used for Vite's build base and React Router basename).
VITE_BASE_PATH=/

# VITE_API_BASE_URL is the base URL for API calls from the frontend (e.g., the portal/API backend URL), for production it should be the actual backend URL.
VITE_API_BASE_URL=https://local.lightapi.net

# VITE_CLIENT_ID and VITE_TENANT_ID are used for authentication (e.g., Azure AD app registration).
VITE_SSO_ENABLED=false
VITE_CLIENT_ID=
VITE_TENANT_ID=
VITE_REDIRECT_URI=


# VITE_PORT is the port where the local frontend development server runs.
VITE_PORT=3000

# Optional local HTTPS for Vite dev server
# Set to true and provide key/cert paths to run dev server over HTTPS.
VITE_HTTPS_ENABLED=true
VITE_HTTPS_KEY_PATH=./server.key
VITE_HTTPS_CERT_PATH=./server.pem
