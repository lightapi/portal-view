# Environment variables
# VITE_BASE_PATH is the base path where the frontend app is served (used for Vite's build base and React Router basename).
VITE_BASE_PATH=/

# VITE_PORTAL_URL is the backend origin used by the Vite dev server proxy (e.g., the portal/API backend URL).
VITE_PORTAL_URL=https://local.lightapi.net
VITE_API_BASE_URL=
